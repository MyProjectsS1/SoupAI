DISCORD_TOKEN=your_discord_bot_token
GEMINI_API_KEY_1=your_first_gemini_key
GEMINI_API_KEY_2=
GEMINI_API_KEY_3=
GEMINI_API_KEY_4=
LOG_CHANNEL_ID=
PORT=3000

BOT_NAME=SOUP AI
SERVER_NAME=Soup Test Server

# all = answers every message, mention = only DMs or mentions
REPLY_MODE=all

# Current defaults, change only if your Gemini account does not have access to one of them.
GEMINI_TEXT_MODELS=gemini-3.5-flash,gemini-2.5-flash,gemini-2.5-flash-lite
GEMINI_IMAGE_MODEL=gemini-3.1-flash-image
GEMINI_TTS_MODEL=gemini-3.1-flash-tts-preview
TTS_VOICE=Kore

MAX_HISTORY_MESSAGES=12
MAX_ATTACHMENT_BYTES=52428800
MAX_TTS_CHARS=1200
IMAGE_SIZE=1K
IMAGE_ASPECT_RATIO=1:1
